  "description": "MCP server for Neptime.io API - Video platform API integration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "neptime-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
